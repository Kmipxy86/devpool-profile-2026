      </div>
    </section>
  </main>

  <footer>
    <div class="wrap">
      <div>สร้างด้วย ❤️ โดย แคทลียา ราโชกาญจน์ (กวาง) · พบค.5 · ผพค.กสข.กฟต.1</div>
      <div class="muted">หน้าเว็บแนะนำตัวสำหรับสมัครเข้า DevPool · HTML + CSS + JavaScript</div>
    </div>
  </footer>

<script>
/* ============================================================
   1) สลับธีม สว่าง/มืด  (DOM + click event)
   ============================================================ */
(function () {
  const root = document.documentElement;
  const btn  = document.getElementById('themeBtn');
  const icon = document.getElementById('themeIcon');
  const text = document.getElementById('themeText');

  // อ่านค่าที่เคยเลือกไว้ (กันพังในบางสภาพแวดล้อมด้วย try/catch)
  let saved = null;
  try { saved = localStorage.getItem('theme'); } catch (e) {}
  if (saved) applyTheme(saved);

  function applyTheme(mode) {
    root.setAttribute('data-theme', mode);
    const dark = mode === 'dark';
    icon.textContent = dark ? '☀️' : '🌙';
    text.textContent = dark ? 'โหมดสว่าง' : 'โหมดมืด';
    try { localStorage.setItem('theme', mode); } catch (e) {}
  }

  btn.addEventListener('click', function () {
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    applyTheme(next);
  });
})();

/* ============================================================
   2) ปุ่มอ่านเพิ่มเติม / ซ่อน  (toggle class + aria)
   ============================================================ */
(function () {
  const btn = document.getElementById('moreBtn');
  const box = document.getElementById('moreText');
  const label = document.getElementById('moreLabel');

  btn.addEventListener('click', function () {
    const open = box.classList.toggle('open');
    btn.classList.toggle('open', open);
    btn.setAttribute('aria-expanded', String(open));
    label.textContent = open ? 'ย่อกลับ' : 'อ่านเพิ่มเติม';
  });
})();

/* ============================================================
   3) ปุ่มนับคลิก + แถบพลังงาน  (counter)
   ============================================================ */
(function () {
  const btn  = document.getElementById('chargeBtn');
  const num  = document.getElementById('energyNum');
  const fill = document.getElementById('meterFill');
  const msg  = document.getElementById('chargeMsg');
  let count = 0;

  const cheers = {
    10:  'เริ่มมีพลังแล้ว! ✨',
    25:  'ไฟกำลังติด 🔥',
    50:  'ครึ่งทางแล้ว สู้ ๆ! 💪',
    75:  'อีกนิดเดียว ใกล้เต็มแล้ว!',
    100: 'พลังเต็ม 100%! ขอบคุณที่ส่งกำลังใจน้า 🎉'
  };

  btn.addEventListener('click', function () {
    count++;
    num.textContent = count;
    const pct = Math.min(count, 100);
    fill.style.width = pct + '%';
    if (cheers[count]) msg.textContent = cheers[count];
    if (count === 100) btn.textContent = '🔋 พลังเต็มแล้ว!';
  });
})();

/* ============================================================
   4) พิมพ์แล้วแสดงผลทันที  (input event)
   ============================================================ */
(function () {
  const input   = document.getElementById('msgInput');
  const preview = document.getElementById('msgPreview');
  const counter = document.getElementById('charCount');
  const empty   = '…ข้อความของคุณจะแสดงตรงนี้';

  input.addEventListener('input', function () {
    const v = input.value;
    preview.textContent = v.trim() ? '“' + v + '”' : empty;
    counter.textContent = v.length;
  });
})();

/* ============================================================
   5) ดึงสภาพอากาศจริงจาก Open-Meteo (fetch / async)
   ============================================================ */
(function () {
  const cities = [
    { name: 'หาดใหญ่', lat: 7.01,  lon: 100.47 },
    { name: 'สงขลา',   lat: 7.20,  lon: 100.60 },
    { name: 'หัวหิน',  lat: 12.57, lon: 99.96 },
    { name: 'กรุงเทพฯ', lat: 13.75, lon: 100.50 }
  ];

  // WMO weather code → ข้อความ + อีโมจิ
  function describe(code) {
    if (code === 0) return ['☀️', 'ท้องฟ้าแจ่มใส'];
    if (code <= 2)  return ['🌤️', 'มีเมฆบางส่วน'];
    if (code === 3) return ['☁️', 'เมฆมาก'];
    if (code <= 48) return ['🌫️', 'มีหมอก'];
    if (code <= 57) return ['🌦️', 'ฝนปรอย'];
    if (code <= 67) return ['🌧️', 'มีฝน'];
    if (code <= 77) return ['🌨️', 'หิมะ'];
    if (code <= 82) return ['🌧️', 'ฝนตกหนัก'];
    if (code <= 99) return ['⛈️', 'พายุฝนฟ้าคะนอง'];
    return ['🌡️', 'ไม่ทราบสภาพอากาศ'];
  }

  const row = document.getElementById('cityRow');
  const box = document.getElementById('weatherBox');

  cities.forEach(function (c, i) {
    const b = document.createElement('button');
    b.className = 'city-btn';
    b.textContent = c.name;
    b.setAttribute('aria-pressed', i === 0 ? 'true' : 'false');
    b.addEventListener('click', function () {
      row.querySelectorAll('.city-btn').forEach(function (x) {
        x.setAttribute('aria-pressed', 'false');
      });
      b.setAttribute('aria-pressed', 'true');
      loadWeather(c);
    });
    row.appendChild(b);
  });

  async function loadWeather(c) {
    box.innerHTML = '<span class="skeleton">กำลังโหลดข้อมูลของ ' + c.name + '…</span>';
    const url = 'https://api.open-meteo.com/v1/forecast?latitude=' + c.lat +
                '&longitude=' + c.lon +
                '&current=temperature_2m,relative_humidity_2m,weather_code,wind_speed_10m' +
                '&timezone=Asia%2FBangkok';
    try {
      const res = await fetch(url);
      if (!res.ok) throw new Error('สถานะ ' + res.status);
      const data = await res.json();
      const cur = data.current;
      const [icon, desc] = describe(cur.weather_code);

      box.innerHTML =
        '<div class="icon" aria-hidden="true">' + icon + '</div>' +
        '<div>' +
          '<div class="temp">' + Math.round(cur.temperature_2m) + '°C</div>' +
          '<div class="desc">' + c.name + ' · ' + desc + '</div>' +
          '<div class="meta">' +
            '<span>ความชื้น <b>' + cur.relative_humidity_2m + '%</b></span>' +
            '<span>ลม <b>' + cur.wind_speed_10m + ' กม./ชม.</b></span>' +
          '</div>' +
        '</div>';
    } catch (err) {
      box.innerHTML = '<span class="skeleton">โหลดข้อมูลไม่สำเร็จ (' + err.message +
                      ') — ลองเลือกเมืองใหม่อีกครั้งนะ</span>';
    }
  }

  loadWeather(cities[0]); // โหลดเมืองแรกอัตโนมัติ
})();
</script>
