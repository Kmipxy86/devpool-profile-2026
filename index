<!DOCTYPE html>
<html lang="th" data-theme="light">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>แคทลียา ราโชกาญจน์ (กวาง) — DevPool</title>
<meta name="description" content="หน้าเว็บแนะนำตัว แคทลียา ราโชกาญจน์ สำหรับสมัครเข้า DevPool · ผพค.กสข.กฟต.1" />

<!-- ฟอนต์: Mitr (หัวข้อ) + IBM Plex Sans Thai Looped (เนื้อหา) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai+Looped:wght@300;400;500;600&family=Mitr:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
  /* ============================================================
     ระบบสี (Design Tokens) — โทน กฟภ. ม่วง + ทอง ธีมพลังงาน
     ============================================================ */
  :root {
    --violet-900: #2a0f4a;
    --violet-700: #5b2a86;
    --violet-500: #7b3fb5;
    --violet-300: #b794e0;
    --gold-500:   #f5b82e;
    --gold-300:   #ffd97a;

    /* โหมดสว่าง */
    --bg:        #f6f2fb;
    --bg-soft:   #ffffff;
    --surface:   #ffffff;
    --ink:       #241338;
    --ink-soft:  #5a4a72;
    --line:      #e7dcf5;
    --brand:     var(--violet-700);
    --brand-2:   var(--violet-500);
    --accent:    #c98a00;
    --accent-bg: #fff6e0;
    --shadow:    0 18px 50px -24px rgba(43, 15, 74, 0.45);
    --glow:      0 0 0 0 rgba(123, 63, 181, 0);
  }

  [data-theme="dark"] {
    --bg:        #150a26;
    --bg-soft:   #1d0f33;
    --surface:   #241541;
    --ink:       #f2e9ff;
    --ink-soft:  #b9a8d6;
    --line:      #38245c;
    --brand:     var(--violet-300);
    --brand-2:   var(--gold-300);
    --accent:    var(--gold-300);
    --accent-bg: #2c1c4a;
    --shadow:    0 24px 60px -28px rgba(0, 0, 0, 0.7);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: "IBM Plex Sans Thai Looped", system-ui, sans-serif;
    background:
      radial-gradient(1100px 600px at 88% -8%, color-mix(in srgb, var(--brand) 22%, transparent), transparent 60%),
      radial-gradient(800px 500px at -5% 10%, color-mix(in srgb, var(--gold-500) 14%, transparent), transparent 55%),
      var(--bg);
    color: var(--ink);
    line-height: 1.65;
    min-height: 100vh;
    transition: background-color .4s ease, color .4s ease;
  }

  h1, h2, h3, .display {
    font-family: "Mitr", "IBM Plex Sans Thai Looped", sans-serif;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: .2px;
  }

  .wrap { width: min(960px, 92vw); margin-inline: auto; }

  a { color: var(--brand); }

  /* ===== แถบบนสุด / ปุ่มสลับธีม ===== */
  .topbar {
    position: sticky; top: 0; z-index: 20;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .topbar .wrap {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 0;
  }
  .brandmark { display: flex; align-items: center; gap: 10px; font-weight: 700;
    font-family: "Mitr", sans-serif; }
  .spark {
    width: 30px; height: 30px; border-radius: 9px;
    background: linear-gradient(140deg, var(--violet-500), var(--violet-900));
    display: grid; place-items: center; color: var(--gold-300);
    box-shadow: 0 6px 18px -6px var(--violet-700);
  }
  .brandmark small { display:block; font-family:"IBM Plex Sans Thai Looped"; font-weight:400;
    font-size:.72rem; color: var(--ink-soft); letter-spacing:0; }

  .theme-btn {
    border: 1px solid var(--line); background: var(--surface);
    color: var(--ink); cursor: pointer;
    padding: 9px 14px; border-radius: 999px; font-family: "IBM Plex Sans Thai Looped";
    font-size: .9rem; font-weight: 500; display: flex; align-items: center; gap: 8px;
    transition: transform .15s ease, border-color .2s ease, background .3s;
  }
  .theme-btn:hover { transform: translateY(-1px); border-color: var(--brand); }
  .theme-btn:active { transform: translateY(0); }

  /* ===== HERO ===== */
  .hero { padding: 64px 0 40px; }
  .hero-grid {
    display: grid; grid-template-columns: 132px 1fr; gap: 28px; align-items: center;
  }
  .avatar {
    width: 132px; height: 132px; border-radius: 28px;
    background: linear-gradient(155deg, var(--violet-500), var(--violet-900) 75%);
    display: grid; place-items: center;
    font-family: "Mitr"; font-weight: 700; font-size: 3.1rem;
    color: var(--gold-300);
    box-shadow: var(--shadow), inset 0 0 0 2px rgba(255,255,255,.08);
    position: relative; overflow: hidden;
  }
  .avatar::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(120deg, transparent 40%, rgba(255,255,255,.25) 50%, transparent 60%);
    transform: translateX(-120%);
    animation: sheen 5.5s ease-in-out 1.2s infinite;
  }
  @keyframes sheen { 0%,70%,100% { transform: translateX(-120%);} 80% { transform: translateX(120%);} }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: .8rem; font-weight: 600; letter-spacing: .5px;
    color: var(--accent); background: var(--accent-bg);
    padding: 5px 12px; border-radius: 999px; margin-bottom: 12px;
  }
  .hero h1 { font-size: clamp(2rem, 5.5vw, 3.1rem); font-weight: 700; }
  .hero h1 .nick { color: var(--brand); }
  .role {
    margin-top: 10px; font-size: 1.05rem; color: var(--ink-soft);
    display: flex; flex-wrap: wrap; gap: 6px 14px;
  }
  .role b { color: var(--ink); font-weight: 600; }
  .tag {
    background: var(--surface); border: 1px solid var(--line);
    padding: 3px 11px; border-radius: 8px; font-size: .92rem;
  }

  /* ===== โครงสร้างทั่วไป ===== */
  section.block { padding: 26px 0; }
  .card {
    background: var(--surface); border: 1px solid var(--line);
    border-radius: 20px; padding: 26px; box-shadow: var(--shadow);
  }
  .section-title {
    display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
  }
  .section-title .num {
    font-family: "Mitr"; font-weight: 700; color: var(--brand-2);
    font-size: .95rem; border: 1.5px solid var(--line); border-radius: 9px;
    padding: 2px 9px;
  }
  .section-title h2 { font-size: 1.35rem; }

  .lead { font-size: 1.06rem; color: var(--ink); }
  .muted { color: var(--ink-soft); }

  /* ===== ทักษะ (chips) ===== */
  .chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 6px; }
  .chip {
    border: 1px solid var(--line); background: var(--bg-soft);
    padding: 7px 14px; border-radius: 999px; font-size: .92rem; font-weight: 500;
    transition: transform .15s ease, border-color .2s, color .2s;
    cursor: default;
  }
  .chip:hover { transform: translateY(-2px); border-color: var(--brand); color: var(--brand); }

  /* ===== ปุ่มอ่านเพิ่มเติม ===== */
  .more { overflow: hidden; max-height: 0; transition: max-height .45s ease, margin .45s ease; }
  .more.open { max-height: 420px; margin-top: 14px; }
  .more p { color: var(--ink-soft); }
  .link-btn {
    margin-top: 14px; background: none; border: none; cursor: pointer;
    color: var(--brand); font-family: "IBM Plex Sans Thai Looped"; font-weight: 600; font-size: .98rem;
    display: inline-flex; align-items: center; gap: 6px; padding: 0;
  }
  .link-btn .ar { transition: transform .3s ease; }
  .link-btn.open .ar { transform: rotate(180deg); }

  /* ===== ส่วน interactive: เครื่องชาร์จพลัง ===== */
  .play-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .energy-num {
    font-family: "Mitr"; font-weight: 700; font-size: 2.6rem; color: var(--brand);
    line-height: 1;
  }
  .meter { height: 12px; border-radius: 999px; background: var(--bg);
    border: 1px solid var(--line); overflow: hidden; margin: 14px 0 18px; }
  .meter > i {
    display: block; height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--violet-500), var(--gold-500));
    transition: width .4s cubic-bezier(.2,.8,.2,1); border-radius: 999px;
  }
  .charge-btn {
    width: 100%; cursor: pointer; border: none; border-radius: 14px;
    padding: 14px; font-family: "Mitr"; font-weight: 600; font-size: 1.02rem;
    color: #fff; background: linear-gradient(135deg, var(--violet-500), var(--violet-700));
    box-shadow: 0 12px 26px -12px var(--violet-700);
    transition: transform .12s ease, filter .2s;
  }
  .charge-btn:hover { filter: brightness(1.08); }
  .charge-btn:active { transform: scale(.97); }
  .charge-msg { margin-top: 12px; font-size: .92rem; color: var(--accent); min-height: 1.4em; font-weight: 500; }

  .field-label { font-size: .9rem; font-weight: 600; color: var(--ink-soft); display:block; margin-bottom: 8px; }
  .field {
    width: 100%; border: 1px solid var(--line); background: var(--bg-soft);
    color: var(--ink); border-radius: 12px; padding: 12px 14px;
    font-family: "IBM Plex Sans Thai Looped"; font-size: 1rem; transition: border-color .2s, box-shadow .2s;
  }
  .field:focus { outline: none; border-color: var(--brand);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--brand) 18%, transparent); }
  .preview-box {
    margin-top: 14px; border: 1px dashed var(--line); border-radius: 12px;
    padding: 16px; background: var(--bg);
  }
  .preview-box .speech { font-size: 1.05rem; }
  .preview-box .count { font-size: .82rem; color: var(--ink-soft); margin-top: 6px; }

  /* ===== สภาพอากาศ (API) ===== */
  .weather { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }
  .weather .icon { font-size: 3.4rem; line-height: 1; }
  .weather .temp { font-family: "Mitr"; font-weight: 700; font-size: 2.4rem; color: var(--brand); }
  .weather .desc { color: var(--ink-soft); }
  .weather .meta { display: flex; gap: 18px; flex-wrap: wrap; margin-top: 6px; font-size: .9rem; }
  .weather .meta b { color: var(--ink); }
  .city-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 18px; }
  .city-btn {
    border: 1px solid var(--line); background: var(--bg-soft); color: var(--ink);
    padding: 7px 14px; border-radius: 999px; cursor: pointer; font-family: "IBM Plex Sans Thai Looped";
    font-size: .9rem; transition: all .2s;
  }
  .city-btn:hover { border-color: var(--brand); }
  .city-btn[aria-pressed="true"] {
    background: var(--brand); color: #fff; border-color: var(--brand);
  }
  [data-theme="dark"] .city-btn[aria-pressed="true"] { color: var(--violet-900); }
  .skeleton { color: var(--ink-soft); font-style: italic; }

  /* ===== footer ===== */
  footer { padding: 40px 0 60px; text-align: center; color: var(--ink-soft); font-size: .9rem; }
  footer .wrap { display: flex; flex-direction: column; gap: 6px; }

  /* ===== แอนิเมชันตอนโหลด ===== */
  .reveal { opacity: 0; transform: translateY(18px); animation: rise .7s ease forwards; }
  .reveal:nth-child(2) { animation-delay: .08s; }
  @keyframes rise { to { opacity: 1; transform: none; } }

  :focus-visible { outline: 3px solid var(--gold-500); outline-offset: 3px; border-radius: 6px; }

  /* ===== responsive ===== */
  @media (max-width: 720px) {
    .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 18px; }
    .avatar { margin-inline: auto; width: 110px; height: 110px; font-size: 2.6rem; }
    .role { justify-content: center; }
    .play-grid { grid-template-columns: 1fr; }
    .brandmark small { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::after { animation: none !important; transition: none !important; }
    html { scroll-behavior: auto; }
  }
</style>
</head>
<body>

  <!-- แถบบน + ปุ่มสลับธีม (interaction #1) -->
  <header class="topbar">
    <div class="wrap">
      <div class="brandmark">
        <span class="spark" aria-hidden="true">⚡</span>
        <span>DevPool Profile<small>ผพค.กสข.กฟต.1 · กฟภ.</small></span>
      </div>
      <button class="theme-btn" id="themeBtn" aria-label="สลับโหมดสว่าง/มืด">
        <span id="themeIcon">🌙</span><span id="themeText">โหมดมืด</span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <main>
     <section class="hero">
      <div class="wrap hero-grid">
        <div class="avatar reveal">
          <span class="avatar-fallback" aria-hidden="true">ก</span>
          <!-- 🖼️ ภาพโปรไฟล์: เปลี่ยน src ให้ตรงกับชื่อไฟล์รูปของคุณ (วางไฟล์รูปไว้โฟลเดอร์เดียวกับ index.html) -->
          <img id="avatarImg" class="avatar-img" src="profile.jpg"
               alt="ภาพโปรไฟล์ แคทลียา ราโชกาญจน์" onerror="this.remove();" />
        </div>
        <div class="reveal">
          <span class="eyebrow">⚡ ผู้สมัคร DevPool</span>
          <h1>แคทลียา ราโชกาญจน์ <span class="nick">(กวาง)</span></h1>
          <div class="role">
            <span class="tag">ตำแหน่ง <b>พบค.5</b></span>
            <span class="tag">สังกัด <b>ผพค.กสข.กฟต.1</b></span>
          </div>
        </div>
      </div>
    </section>

    <!-- เหตุผลที่อยากเข้า DevPool -->
    <section class="block">
      <div class="wrap">
        <div class="card reveal">
          <div class="section-title">
            <span class="num">01</span>
            <h2>ทำไมถึงอยากเข้า DevPool</h2>
          </div>
          <p class="lead">
            อยากพัฒนาการทำงานไปพร้อมกับการเรียนรู้สิ่งใหม่ ที่สามารถนำมาพัฒนา ต่อยอด
            และสร้างสรรค์งานที่เป็นประโยชน์ต่อองค์กร
          </p>

          <div class="more" id="moreText">
            <p>
              อยากแก้ไขระบบงานที่ซ้ำซ้อนและล่าช้า ให้มีประสิทธิภาพมากยิ่งขึ้น
              แม้บางงานจะเป็นแค่โปรเจกต์เล็ก ๆ ฉันก็อยากทำให้งานนั้นมีประโยชน์
              ต่อเพื่อน ๆ ในองค์กรให้ได้มากที่สุด
            </p>
          </div>

          <button class="link-btn" id="moreBtn" aria-expanded="false" aria-controls="moreText">
            <span id="moreLabel">อ่านเพิ่มเติม</span> <span class="ar">▾</span>
          </button>
        </div>
      </div>
    </section>

    <!-- ทักษะ -->
    <section class="block">
      <div class="wrap">
        <div class="card reveal">
          <div class="section-title">
            <span class="num">02</span>
            <h2>สิ่งที่ต้องการพัฒนา &amp; สนใจ</h2>
          </div>
          <p class="muted">เครื่องมือและทักษะที่ใช้สร้างงานให้เพื่อนร่วมงานใช้จริง — แก้ไขรายการนี้ได้ตามต้องการ</p>
          <!-- 🔧 แก้ไขรายการทักษะของคุณได้ที่นี่ -->
          <div class="chips">
            <span class="chip">HTML / CSS</span>
            <span class="chip">JavaScript</span>
            <span class="chip">Google Apps Script</span>
            <span class="chip">Google Sheets</span>
            <span class="chip">เว็บแอป &amp; Dashboard</span>
            <span class="chip">e-Form ระบบจัดซื้อจัดจ้าง</span>
            <span class="chip">ออกแบบ UX ให้ใช้ง่าย</span>
            <span class="chip">AI</span>
          </div>
        </div>
      </div>
    </section>

    <!-- โซน interactive: เครื่องชาร์จพลัง + พิมพ์สด -->
    <section class="block">
      <div class="wrap">
        <div class="play-grid">

          <!-- interaction #2: ปุ่มนับคลิก + แถบพลังงาน -->
          <div class="card reveal">
            <div class="section-title">
              <span class="num">03</span>
              <h2>ส่งกำลังใจ ⚡</h2>
            </div>
            <p class="muted">กดปุ่มเพื่อชาร์จพลังให้กวางหน่อยน้า — ครบ 100 มีเซอร์ไพรส์</p>
            <div style="margin-top:14px">
              <span class="energy-num" id="energyNum">0</span>
              <span class="muted"> คลิก</span>
            </div>
            <div class="meter"><i id="meterFill"></i></div>
            <button class="charge-btn" id="chargeBtn">⚡ ชาร์จพลัง +1</button>
            <p class="charge-msg" id="chargeMsg"></p>
          </div>

          <!-- interaction #3: พิมพ์แล้วแสดงผลทันที -->
          <div class="card reveal">
            <div class="section-title">
              <span class="num">04</span>
              <h2>ฝากข้อความถึงกวาง</h2>
            </div>
            <label class="field-label" for="msgInput">พิมพ์อะไรก็ได้ แล้วดูตัวอย่างด้านล่างทันที</label>
            <input class="field" id="msgInput" type="text" maxlength="120"
                   placeholder="เช่น ยินดีต้อนรับสู่ DevPool!" />
            <div class="preview-box">
              <div class="speech" id="msgPreview">…ข้อความของคุณจะแสดงตรงนี้</div>
              <div class="count"><span id="charCount">0</span>/120 ตัวอักษร</div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ส่วนเสริม: ดึง API สภาพอากาศจริง -->
    <section class="block">
      <div class="wrap">
        <div class="card reveal">
          <div class="section-title">
            <span class="num">05</span>
            <h2>สภาพอากาศตอนนี้ (ข้อมูลสด)</h2>
          </div>
          <p class="muted">ดึงข้อมูลจริงจาก Open-Meteo API ด้วย <code>fetch()</code> — เลือกเมืองได้</p>

          <div class="city-row" id="cityRow" role="group" aria-label="เลือกเมือง">
            <!-- ปุ่มเมืองถูกสร้างด้วย JS -->
